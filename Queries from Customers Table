SELECT * FROM customer
WHERE first_name = 'Mary'
OR first_name = 'Elizabeth'
OR first_name = 'Donna';


SELECT * FROM customer
WHERE first_name IN ('Mary', 'Elizabeth', 'Donna');


SELECT * FROM actor WHERE first_name NOT IN ('Mary', 'Elizabeth', 'Donna');


SELECT * from customer WHERE first_name LIKE 'GRA%';

SELECT * from customer WHERE first_name LIKE 'DON%A';

SELECT * from customer
WHERE first_name LIKE 'jo_';

SELECT * from customer WHERE first_name LIKE 'j_n'

SELECT * FROM customer WHERE first_name LIKE 'matt%w' OR (first_name LIKE 'don_a');

SELECT first_name, last_name 
FROM customer
WHERE first_name IN ('Mary', 'Elizabeth', 'Donna')
OR first_name LIKE 'MAR%'
ORDER BY last_name ASC;


SELECT first_name, LENGTH(first_name) FROM customer;

SELECT first_name, LENGTH(last_name)
FROM customer;

SELECT CONCAT(first_name, ' ', last_name) FROM customer;


SELECT CONCAT(first_name, ' ', last_name) AS full_name
FROM customer;


SELECT CONCAT(first_name, ' ', last_name) AS full_name,
LENGTH(CONCAT(first_name, ' ', last_name)) AS full_name_length
FROM customer;

SELECT CONCAT(CONCAT(UPPER(LEFT(first_name,1)), LOWER(RIGHT(first_name, LENGTH(first_name)-1))), ' ', LOWER(last_name)) AS full_name
FROM customer;


SELECT CONCAT(CONCAT(UPPER(LEFT(first_name,1)), LOWER(RIGHT(first_name, LENGTH(first_name)-1))), ' ',CONCAT(UPPER(LEFT(last_name,1)),
 LOWER(RIGHT(last_name, LENGTH(last_name)-1)))) AS full_name FROM customer;
